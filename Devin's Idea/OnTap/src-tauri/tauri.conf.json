{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnTap",
  "version": "0.1.0",
  "identifier": "app.ontap.demo",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx serve ../src -p 1420 --cors",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OnTap",
        "width": 1280,
        "height": 920,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
